---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Couples & Relational Therapists Winnipeg | West End Therapy" description="Find a couples therapist in Winnipeg at West End Therapy. All therapists are Master's-level and trained in relational approaches.">
  <section class="page-hero">
    <div class="wrap">
      <h1>Relational Therapists</h1>
      <p>Our couples and relational therapists work with partners and families to improve communication, rebuild connection, and navigate challenges together.</p>
      <a href="/therapists" class="btn btn-outline" style="margin-top:1.25rem;display:inline-flex;">View All Therapists</a>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="thx-grid">
          <a href="/therapists/christine-holowick" class="thx-card">
