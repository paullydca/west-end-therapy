---
import Layout from '../layouts/Layout.astro';
---
<Layout title="EMDR Therapists Winnipeg | West End Therapy" description="Find an EMDR-trained therapist in Winnipeg at West End Therapy. Evidence-based trauma processing for PTSD and more.">
  <section class="page-hero">
    <div class="wrap">
      <h1>EMDR-Practicing Therapists</h1>
      <p>The following therapists are trained in EMDR (Eye Movement Desensitization and Reprocessing) and offer this evidence-based trauma treatment.</p>
      <a href="/west-end-therapy/therapists" class="btn btn-outline" style="margin-top:1.25rem;display:inline-flex;">View All Therapists</a>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="thx-grid">
          <a href="/west-end-therapy/therapists/christine-holowick" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/9b14074c0dc640b2a34d4622c188f7a4/dsc_0164.jpg" alt="Christine Holowick" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Christine Holowick</div>
              <span class="thx-card__creds">MMFT, BSW/RSW</span>
              <span class="thx-card__role">Clinic Director & Therapist</span>
              <p class="thx-card__spec">Individuals (16+), Couples, EMDR</p>
              <div class="thx-card__avail">Closed to new referrals</div>
            </div>
          </a>
          <a href="/west-end-therapy/therapists/marie-baffoe" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/e917830f941b4992ba58b10d9062ea80/230910ls117.jpg" alt="Marie Baffoe" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Marie Baffoe</div>
              <span class="thx-card__creds">MMFT, MSW/RSW</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals (16+), Couples, Families, EMDR</p>
              <div class="thx-card__avail waitlist">Wait List</div>
            </div>
          </a>
          <a href="/west-end-therapy/therapists/michael-kurek" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/32690e2670654fbd9f2c62c14bddd621/michael-k-bio-phot.jpg" alt="Michael Kurek" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Michael Kurek</div>
              <span class="thx-card__creds">MMFT</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Adults, Couples, Families, EMDR</p>
              <div class="thx-card__avail">Mon, Tues & Wed 3 – 9 PM</div>
            </div>
          </a>
          <a href="/west-end-therapy/therapists/olivia-barker" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/63b7dd85df5c41eb98f227a9e8e5ed7b/image_50791937-1.jpg" alt="Olivia Barker" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Olivia Barker</div>
              <span class="thx-card__creds">MSW/RSW</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals (16+), EMDR</p>
              <div class="thx-card__avail waitlist">Wait List</div>
            </div>
          </a>
          <a href="/west-end-therapy/therapists/deanna-lutzek" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/4724021c5b218e89c24e1f4162a14b7e/image0.jpeg" alt="Deanna Lutzek" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Deanna Lutzek</div>
              <span class="thx-card__creds">MA, CCC</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Children (7+), Teens, Adults, EMDR</p>
              <div class="thx-card__avail">Tues 9 AM – 2:45 PM · Fri 4 PM – 7 PM</div>
            </div>
          </a>
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/west-end-therapy/#intake-form" class="btn btn-teal">Fill Out Our Intake Form</a>
      </div>
    </div>
  </section>
</Layout>
<style>
.page-hero{background:linear-gradient(135deg,var(--teal-light),var(--teal-pale));padding-block:clamp(3rem,7vw,5rem);border-bottom:1px solid var(--border)}
.page-hero h1{margin-block:.5rem .75rem}
.page-hero p{max-width:55ch;font-size:1.05rem}
.thx-card__creds{font-size:.7rem;font-weight:600;letter-spacing:.08em;color:var(--mid);display:block;margin-bottom:.15rem}
</style>