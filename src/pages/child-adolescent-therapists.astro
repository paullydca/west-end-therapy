---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Child & Adolescent Therapists Winnipeg | West End Therapy" description="Find a child or teen therapist in Winnipeg at West End Therapy. Compassionate support for children and adolescents.">
  <section class="page-hero">
    <div class="wrap">
      <h1>Child & Adolescent Therapists</h1>
      <p>Our child and adolescent therapists specialize in age-appropriate, evidence-based support for young people and their families.</p>
      <a href="/therapists" class="btn btn-outline" style="margin-top:1.25rem;display:inline-flex;">View All Therapists</a>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="thx-grid">
          <a href="/therapists/caroline-beattie" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/eacb74ba64194829865812de8032d02c/cb-profile-pic.jpeg" alt="Caroline Beattie" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Caroline Beattie</div>
              <span class="thx-card__creds">MMFT</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals (16+), Couples, Families with Children/Youth</p>
              <div class="thx-card__avail waitlist">Wait List</div>
            </div>
          </a>
          <a href="/therapists/brianna-bowen" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/90022c5db0674e908db3d1c70f8ca96c/img_4751.jpeg" alt="Brianna Bowen" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Brianna Bowen</div>
              <span class="thx-card__creds">MSW/RSW</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Children & Teens, Adults, Families</p>
              <div class="thx-card__avail">Tues 9 AM – 4 PM</div>
            </div>
          </a>
          <a href="/therapists/lena-morina" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/29ad796eaa33dd18a6135682541f4c6f/img_4286.jpeg" alt="Lena Morina" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Lena Morina</div>
              <span class="thx-card__creds">MMFT</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Families (children 8+) & Teens, Individuals, Couples</p>
              <div class="thx-card__avail">Mon & Wed 5 PM – 9 PM</div>
            </div>
          </a>
          <a href="/therapists/deanna-lutzek" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/4724021c5b218e89c24e1f4162a14b7e/image0.jpeg" alt="Deanna Lutzek" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Deanna Lutzek</div>
              <span class="thx-card__creds">MA, CCC</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Children (7+), Teens, Adults, EMDR</p>
              <div class="thx-card__avail">Tues 9 AM – 2:45 PM · Fri 4 PM – 7 PM</div>
            </div>
          </a>
          <a href="/therapists/ioanna-charatsari" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/6511fcefc7a0424038d40dddaa532f4f/ioanna-bio-photo2.jpeg" alt="Ioanna Charatsari" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Ioanna Charatsari</div>
              <span class="thx-card__creds">MMFT</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals, Couples, Families (age 6+)</p>
              <div class="thx-card__avail">Tue & Thur 5 PM – 9 PM</div>
            </div>
          </a>
          <a href="/therapists/julie-letkeman" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/57c95b618c88fe42e1648c96d3e74db5/julie-l-bio-photo.jpg" alt="Julie Letkeman" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Julie Letkeman</div>
              <span class="thx-card__creds">MMFT</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals (Adults & Youth 10+), Couples, Families</p>
              <div class="thx-card__avail">Wed 6 PM – 9 PM</div>
            </div>
          </a>
          <a href="/therapists/kristin-millar" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/fe3316c270838a7b73e566d32ca58fa4/km-picture.jpeg" alt="Kristin Millar" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Kristin Millar</div>
              <span class="thx-card__creds">MMFT, BSW/RSW</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Individuals (Adults & Youth 4+), Couples, Families</p>
              <div class="thx-card__avail">Tue & Wed 5:30 – 9 PM</div>
            </div>
          </a>
          <a href="/therapists/katrina-forget" class="thx-card">
            <img src="https://westendtherapy.ca/ws/media-library/6f4b5f265199d40aa7c751f7a09b050d/kforget-pic.png" alt="Katrina Forget" loading="lazy"/>
            <div class="thx-card__body">
              <div class="thx-card__name">Katrina Forget</div>
              <span class="thx-card__creds">MACP, CCC</span>
              <span class="thx-card__role">Associate Therapist</span>
              <p class="thx-card__spec">Children & Youth aged 3+, Parents</p>
              <div class="thx-card__avail">Mon 5 PM – 9 PM · Sat 10 AM – 3 PM</div>
            </div>
          </a>
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/#intake-form" class="btn btn-teal">Fill Out Our Intake Form</a>
      </div>
    </div>
  </section>
</Layout>
<style>
.page-hero{background:linear-gradient(135deg,var(--teal-light),var(--teal-pale));padding-block:clamp(3rem,7vw,5rem);border-bottom:1px solid var(--border)}
.page-hero h1{margin-block:.5rem .75rem}
.page-hero p{max-width:55ch;font-size:1.05rem}
.thx-card__creds{font-size:.7rem;font-weight:600;letter-spacing:.08em;color:var(--mid);display:block;margin-bottom:.15rem}
</style>